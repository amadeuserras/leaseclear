{#==============================================================================
  simple_lease.j2  —  Minimal residential lease (the "short / sparse" edge case)
==============================================================================#}
<h1 class="doc-title">RESIDENTIAL LEASE AGREEMENT</h1>

<p class="clause">
  <span class="clause-num">1.</span>
  <span class="clause-title">PARTIES.</span>
  This Residential Lease Agreement ("Agreement") is made on
  {{ agreement_date }} between {{ landlord.name }}, with a mailing address of
  {{ landlord.address }} ("Landlord"), and
  {{ tenants | map(attribute='name') | join(', ') }}
  ("Tenant{{ 's' if tenants | length > 1 else '' }}").
</p>

<p class="clause">
  <span class="clause-num">2.</span>
  <span class="clause-title">PROPERTY.</span>
  The Landlord agrees to lease to the Tenant the property located at
  {{ property.address }}, a {{ property.type }} with {{ property.bedrooms }}
  bedroom(s) and {{ property.bathrooms }} bathroom(s) (the "Premises").
</p>

<p class="clause">
  <span class="clause-num">3.</span>
  <span class="clause-title">TERM.</span>
  This Agreement begins on {{ term.start }} and ends on {{ term.end }}.
</p>

<p class="clause">
  <span class="clause-num">4.</span>
  <span class="clause-title">RENT.</span>
  The Tenant shall pay ${{ "%.2f" | format(rent.amount) }} per month,
  due on the {{ rent.due_day }} day of each month.
</p>

<p class="clause">
  <span class="clause-num">5.</span>
  <span class="clause-title">SECURITY DEPOSIT.</span>
{%- if deposit.required %}
  The Tenant shall pay a security deposit of ${{ "%.2f" | format(deposit.amount) }}.
  The deposit, less any itemized deductions, shall be returned within
  {{ deposit.return_days }} days after the end of the Term.
{%- else %}
  No security deposit is required under this Agreement.
{%- endif %}
</p>

<div class="signatures">
  <div class="section-heading">SIGNATURES</div>

  <div class="sig-block">
    <div class="sig-line">Landlord: _________________________&nbsp;&nbsp;Date: __________</div>
    <div class="sig-name">{{ landlord.name }}</div>
  </div>

{% for t in tenants -%}
  <div class="sig-block">
    <div class="sig-line">Tenant: ___________________________&nbsp;&nbsp;Date: __________</div>
    <div class="sig-name">{{ t.name }}</div>
  </div>
{% endfor -%}
</div>
