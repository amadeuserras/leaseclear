<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8" />
  <style>
    body {
      font-family: {{ theme.font_family }};
      font-size: {{ theme.font_size }};
      line-height: {{ theme.line_height }};
      color: {{ theme.body_color }};
      margin: 0;
    }

    .doc-header {
      margin-bottom: 20px;
      padding-bottom: 10px;
      border-bottom: 1px solid #d0d0d0;
    }

    .doc-header.has-brand {
      display: block;
    }

    .brand {
      font-size: 13pt;
      font-weight: bold;
      color: {{ theme.accent }};
      letter-spacing: 0.02em;
    }

    .tagline {
      font-size: 8.5pt;
      color: #666;
      margin-top: 2px;
    }

    h1.doc-title {
      font-size: 15pt;
      font-weight: bold;
      color: {{ theme.title_color }};
      text-align: center;
      margin: 16px 0 20px;
      letter-spacing: 0.04em;
    }

    .clause {
      margin-bottom: 10px;
    }

    .clause-num {
      color: {{ theme.accent }};
      font-weight: bold;
    }

    .clause-title {
      font-weight: bold;
    }

    .sub-clause {
      margin: 4px 0 4px 16px;
    }

    .section-heading {
      font-size: 11pt;
      font-weight: bold;
      color: {{ theme.title_color }};
      margin: 18px 0 8px;
      padding: 4px 0;
      border-bottom: 1px solid {{ theme.accent }};
    }

    table.fees {
      border-collapse: collapse;
      width: 100%;
      margin: 8px 0 16px;
      font-size: 9.5pt;
    }

    table.fees th {
      background-color: {{ theme.accent }};
      color: #fff;
      text-align: left;
      padding: 5px 10px;
      font-weight: bold;
    }

    table.fees td {
      border: 1px solid #ccc;
      padding: 4px 10px;
    }

    table.fees tr.total td {
      font-weight: bold;
      border-top: 2px solid {{ theme.accent }};
    }

    table.fees td.amount {
      text-align: right;
      width: 100px;
    }

    ul.pet-list {
      margin: 4px 0 4px 20px;
      padding: 0;
    }

    ul.pet-list li {
      margin-bottom: 2px;
    }

    .signatures {
      margin-top: 24px;
      padding-top: 12px;
      border-top: 1px solid #ccc;
    }

    .sig-block {
      margin-bottom: 20px;
    }

    .sig-line {
      margin-bottom: 4px;
    }

    .sig-name {
      font-size: 9.5pt;
      color: #555;
    }

    .meta-line {
      font-size: 9.5pt;
      color: #555;
      margin-bottom: 16px;
    }

    .reserved {
      color: #999;
      font-style: italic;
    }
  </style>
</head>
<body>
{% if theme.header_brand -%}
  <div class="doc-header has-brand">
    <div class="brand">{{ theme.header_brand }}</div>
    {% if theme.header_tagline -%}
    <div class="tagline">{{ theme.header_tagline }}</div>
    {% endif -%}
  </div>
{% endif -%}
{{ content }}
</body>
</html>
